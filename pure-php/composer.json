{
    "name": "hexagon-practise/pure-php",
    "description": "Pure PHP: healthcare appointment scheduling with Redis — Hexagonal Architecture",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "predis/predis": "^2.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "HexagonPractise\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HexagonPractise\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8080 -t public",
        "format": "@composer --working-dir=.. format",
        "format:check": "@composer --working-dir=.. format:check",
        "format:changed": "@composer --working-dir=.. format:changed",
        "format:changed:check": "@composer --working-dir=.. format:changed:check",
        "spaces:check": "@composer --working-dir=.. spaces:check",
        "phpstan": "@composer --working-dir=.. phpstan",
        "phpstan:changed": "@composer --working-dir=.. phpstan:changed"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable"
}
