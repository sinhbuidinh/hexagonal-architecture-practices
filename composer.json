{
    "name": "hexagon-practise/monorepo",
    "description": "Dev tooling for the hexagon-practise monorepo",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.2"
    },
    "autoload-dev": {
        "psr-4": {
            "HexagonPractise\\Tools\\PhpCsFixer\\": "tools/php-cs-fixer/",
            "HexagonPractise\\Tools\\PhpStan\\": "tools/phpstan/"
        }
    },
    "scripts": {
        "format": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes",
        "format:check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --allow-risky=yes",
        "format:laravel": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes laravel/app laravel/routes laravel/tests",
        "format:check:laravel": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --allow-risky=yes laravel/app laravel/routes laravel/tests",
        "format:symfony": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes symfony/src",
        "format:check:symfony": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --allow-risky=yes symfony/src",
        "format:pure-php": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes pure-php/src pure-php/tests pure-php/public pure-php/bin",
        "format:check:pure-php": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --allow-risky=yes pure-php/src pure-php/tests pure-php/public pure-php/bin",
        "format:changed": "bash tools/format-changed.sh",
        "format:changed:check": "bash tools/format-changed.sh --check",
        "format:changed:laravel": "PACKAGE=laravel bash tools/format-changed.sh",
        "format:changed:check:laravel": "PACKAGE=laravel bash tools/format-changed.sh --check",
        "format:changed:symfony": "PACKAGE=symfony bash tools/format-changed.sh",
        "format:changed:check:symfony": "PACKAGE=symfony bash tools/format-changed.sh --check",
        "format:changed:pure-php": "PACKAGE=pure-php bash tools/format-changed.sh",
        "format:changed:check:pure-php": "PACKAGE=pure-php bash tools/format-changed.sh --check",
        "spaces:check": "bash tools/check-spaces.sh",
        "spaces:check:laravel": "PACKAGE=laravel bash tools/check-spaces.sh",
        "spaces:check:symfony": "PACKAGE=symfony bash tools/check-spaces.sh",
        "spaces:check:pure-php": "PACKAGE=pure-php bash tools/check-spaces.sh",
        "spaces:fix": "bash tools/fix-spaces.sh",
        "phpstan": [
            "@phpstan:pure-php",
            "@phpstan:laravel",
            "@phpstan:symfony"
        ],
        "phpstan:pure-php": "phpstan analyse --configuration=phpstan/pure-php.neon --memory-limit=512M",
        "phpstan:laravel": "phpstan analyse --configuration=phpstan/laravel.neon --memory-limit=512M",
        "phpstan:symfony": "phpstan analyse --configuration=phpstan/symfony.neon --memory-limit=512M",
        "phpstan:changed": "bash tools/phpstan-changed.sh",
        "phpstan:changed:laravel": "PACKAGE=laravel bash tools/phpstan-changed.sh",
        "phpstan:changed:symfony": "PACKAGE=symfony bash tools/phpstan-changed.sh",
        "phpstan:changed:pure-php": "PACKAGE=pure-php bash tools/phpstan-changed.sh",
        "phpstan:baseline": [
            "phpstan analyse --configuration=phpstan/pure-php.neon --memory-limit=512M --generate-baseline=phpstan-baseline-pure-php.neon",
            "phpstan analyse --configuration=phpstan/laravel.neon --memory-limit=512M --generate-baseline=phpstan-baseline-laravel.neon",
            "phpstan analyse --configuration=phpstan/symfony.neon --memory-limit=512M --generate-baseline=phpstan-baseline-symfony.neon",
            "@spaces:fix"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
