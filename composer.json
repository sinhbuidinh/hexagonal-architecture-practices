{
    "name": "hexagon-practise/monorepo",
    "description": "Dev tooling for the hexagon-practise monorepo",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.2"
    },
    "autoload-dev": {
        "psr-4": {
            "HexagonPractise\\Tools\\PhpCsFixer\\": "tools/php-cs-fixer/",
            "HexagonPractise\\Tools\\PhpStan\\": "tools/phpstan/"
        }
    },
    "scripts": {
        "format": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes",
        "format:check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --allow-risky=yes",
        "format:changed": "bash tools/format-changed.sh",
        "format:changed:check": "bash tools/format-changed.sh --check",
        "spaces:check": "bash tools/check-spaces.sh",
        "spaces:fix": "bash tools/fix-spaces.sh",
        "phpstan:changed": "bash tools/phpstan-changed.sh",
        "phpstan": [
            "phpstan analyse --configuration=phpstan/pure-php.neon --memory-limit=512M",
            "phpstan analyse --configuration=phpstan/laravel.neon --memory-limit=512M",
            "phpstan analyse --configuration=phpstan/symfony.neon --memory-limit=512M"
        ],
        "phpstan:baseline": [
            "phpstan analyse --configuration=phpstan/pure-php.neon --memory-limit=512M --generate-baseline=phpstan-baseline-pure-php.neon",
            "phpstan analyse --configuration=phpstan/laravel.neon --memory-limit=512M --generate-baseline=phpstan-baseline-laravel.neon",
            "phpstan analyse --configuration=phpstan/symfony.neon --memory-limit=512M --generate-baseline=phpstan-baseline-symfony.neon",
            "@spaces:fix"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
